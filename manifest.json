{
  "manifest_version": 3,
  "name": "Coupang Detail Import",
  "version": "0.1.0",
  "description": "Import the current Coupang product page into the local detail-check pipeline.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://www.coupang.com/*",
    "http://127.0.0.1:5000/*",
    "http://127.0.0.1:5001/*",
    "http://localhost:5000/*",
    "http://localhost:5001/*",
    "http://100.118.184.5:5000/*"
  ],
  "action": {
    "default_title": "Coupang Detail Import",
    "default_popup": "popup.html"
  }
}
